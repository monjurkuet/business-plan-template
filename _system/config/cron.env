# Environment variables for the self-evolving pipeline cron job
# Copy to _system/config/cron.env and fill in values

# LLM API
OPENPAI_BASE_URL=https://llm.datasolved.org/v1
OPENPAI_API_KEY=sk-vqxAskCoUVgzhVybz

# Pipeline limits
MAX_QUERIES_PER_RUN=80
MAX_EVIDENCE_PER_RUN=60
CONFIDENCE_THRESHOLD=0.55
MAX_SEARCH_QUERIES=50

# Performance
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_REQUEST_RETRIES=0
LLM_SKIP_MODELS_PREFLIGHT=1
SEARCH_PLAN_REVIEW_TIMEOUT_SECONDS=30
SEARCH_PARALLELISM=8
