# Environment variables for the self-evolving pipeline cron job
# Copy to .env and fill in values

SEARCH_API_BASE=https://search.datasolved.org
LLM_API_BASE=https://llm.datasolved.org/v1
LLM_API_KEY=sk-your-key-here

GITHUB_REPO=monjurkuet/business-plan-template
GITHUB_BRANCH=main

TZ=Asia/Dhaka
PYTHONUNBUFFERED=1

# Pipeline limits
MAX_QUERIES_PER_RUN=120
MAX_LLM_COST_USD_PER_RUN=8
AUTO_ARCHIVE_DAYS=120

# Run mode: dry-run = no git push, live = full auto
RUN_MODE=dry-run
