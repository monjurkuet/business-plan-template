{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Competitor Profile",
  "description": "Structured competitor data — source of truth for markdown generation",
  "type": "object",
  "required": ["competitor_id", "sector", "name", "slug", "last_verified_at", "freshness_status", "confidence_score"],
  "properties": {
    "competitor_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "sector": {"type": "string"},
    "name": {"type": "string"},
    "slug": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "hq_city": {"type": ["string", "null"]},
    "business_model": {"type": "string", "enum": ["service", "product", "marketplace", "hybrid", "subscription", "unknown"]},
    "subsegments": {"type": "array", "items": {"type": "string"}},
    "channels": {"type": "array", "items": {"type": "string"}},
    "facebook_handle": {"type": ["string", "null"], "format": "uri"},
    "facebook_verified_status": {"type": "string", "enum": ["verified", "partially_verified", "unverified", "unavailable"]},
    "website": {"type": ["string", "null"], "format": "uri"},
    "phone": {"type": "array", "items": {"type": "string"}},
    "email": {"type": "array", "items": {"type": "string"}},
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "city": {"type": "string"},
          "address": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "pricing": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service": {"type": "string"},
          "price_bdt": {"type": ["number", "null"]},
          "price_range_bdt": {"type": ["string", "null"]},
          "currency": {"type": "string", "default": "BDT"},
          "observed_at": {"type": "string", "format": "date-time"},
          "source_id": {"type": "string"}
        }
      }
    },
    "estimated_revenue": {
      "type": "object",
      "properties": {
        "value": {"type": ["number", "null"]},
        "range": {"type": "string"},
        "currency": {"type": "string"},
        "year": {"type": ["number", "null"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "funding_signals": {"type": "array", "items": {"type": "object"}},
    "customer_segments": {"type": "array", "items": {"type": "string"}},
    "sourcing_notes": {"type": "array", "items": {"type": "object"}},
    "regulatory_notes": {"type": "array", "items": {"type": "object"}},
    "review_summary": {
      "type": "object",
      "properties": {
        "rating_estimate": {"type": ["number", "null"], "minimum": 0, "maximum": 5},
        "review_volume_estimate": {"type": ["number", "null"]},
        "source_id": {"type": "string"}
      }
    },
    "seasonality": {"type": "array", "items": {"type": "object"}},
    "last_verified_at": {"type": "string", "format": "date-time"},
    "freshness_status": {"type": "string", "enum": ["fresh", "stale", "critical"]},
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_ids": {"type": "array", "items": {"type": "string"}}
  }
}
