{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evidence Item",
  "description": "A single search result with extracted facts and provenance",
  "type": "object",
  "required": ["evidence_id", "sector", "query", "retrieved_at"],
  "properties": {
    "evidence_id": {"type": "string"},
    "sector": {"type": "string"},
    "entity_type": {"type": "string", "enum": ["competitor", "sector", "policy", "pricing", "sentiment"]},
    "entity_slug": {"type": "string"},
    "query": {"type": "string"},
    "query_family": {"type": "string"},
    "query_score_prior": {"type": "number"},
    "search_provider": {"type": "string", "default": "search.datasolved.org"},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "source_url": {"type": ["string", "null"], "format": "uri"},
    "source_domain": {"type": ["string", "null"]},
    "source_type": {"type": "string", "enum": ["official", "news", "social", "government", "research", "directory", "forum", "unknown"]},
    "title": {"type": ["string", "null"]},
    "snippet": {"type": ["string", "null"]},
    "extracted_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {"type": "string"},
          "value": {},
          "unit": {"type": ["string", "null"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "source_quality_score": {"type": "number", "minimum": 0, "maximum": 1},
    "recency_score": {"type": "number", "minimum": 0, "maximum": 1},
    "consistency_score": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
