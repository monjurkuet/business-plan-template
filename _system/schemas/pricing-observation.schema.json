{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pricing Observation",
  "type": "object",
  "required": ["sector", "competitor_slug", "service_product", "observed_at", "source_id"],
  "properties": {
    "sector": {"type": "string"},
    "competitor_slug": {"type": "string"},
    "competitor_name": {"type": "string"},
    "service_product": {"type": "string"},
    "price_bdt": {"type": ["number", "null"]},
    "price_range_bdt": {"type": ["string", "null"]},
    "package_tier": {"type": ["string", "null"], "enum": ["basic", "standard", "premium", "enterprise", "custom", null]},
    "promotion": {"type": ["string", "null"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "source_url": {"type": ["string", "null"]},
    "source_id": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
